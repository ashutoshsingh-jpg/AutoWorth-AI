# Copy this file to .env for local development.
# In production (Render, etc.), set these as real environment variables/secrets
# instead -- do not commit a real .env file.

# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=True

# App
APP_NAME=ValueTrack AI

# Paths (leave unset to use the project defaults)
# INSTANCE_DIR=instance
# DATABASE_PATH=instance/predictions.db
# LOGS_DIR=logs
# LOG_FILE=logs/app.log
# MODEL_PATH=car_price_model.pkl
# REPORTS_DIR=instance/reports

# Pagination
HISTORY_PAGE_SIZE=10
